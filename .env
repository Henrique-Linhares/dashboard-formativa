# MySQL (serviço mysql)
MYSQL_ROOT_PASSWORD=root_pass
# Define a senha do usuário root do MySQL.
# É obrigatória na primeira inicialização do banco.
# Sem ela o container do MySQL não sobe.
MYSQL_DATABASE=dashboard_formativa
# Nome do banco de dados que será criado automaticamente
# na primeira vez que o container inicializar.
MYSQL_USER=app_user
# Usuário adicional (não-root) criado automaticamente.
# Esse usuário será usado pela aplicação Flask.
MYSQL_PASSWORD=app_pass
# Senha do usuário da aplicação (app_user).
# Deve ser igual à usada no backend para conexão funcionar.
# Variáveis utilizadas pela aplicação Flask para conectar no banco.

# Backend (serviço backend)
DB_HOST=mysql
# Nome do host do banco.
# No Docker Compose, o nome do serviço (mysql)
# vira automaticamente o hostname interno da rede.
DB_PORT=3306
# Porta interna do MySQL dentro do container.
# Mesmo que o host use 3316, internamente continua sendo 3306.
DB_USER=app_user
# Usuário que o Flask usará para se conectar ao banco.
# Deve coincidir com MYSQL_USER.
DB_PASSWORD=app_pass
# Senha do usuário da aplicação.
# Deve coincidir com MYSQL_PASSWORD.
DB_NAME=dashboard_formativa
# Nome do banco que a aplicação vai utilizar.
# Deve coincidir com MYSQL_DATABASE.
# Flask
# Configurações específicas da aplicação Flask.

# Flask
FLASK_SECRET_KEY=mortadela
# Chave secreta usada pelo Flask para:
# - Gerenciar sessões
# - Flash messages
# - Proteção de cookies
# Em produção deve ser uma chave forte e aleatória.
FLASK_DEBUG=1
# Define se o modo debug está ativo.
# 1 = ativado (mostra erros detalhados)
# 0 = desativado (modo mais seguro para produção)
